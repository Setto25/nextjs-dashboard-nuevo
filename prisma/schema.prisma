// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Modelo de DB de pruebas
model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categoria {
  id             Int             @id @default(autoincrement())
  categoria      String          @unique
  nombre         String          @unique
  menuCategorias MenuCategoria[] // Relación inversa necesaria para establecer la relacion fk
}


model MenuCategoria {
  id                  Int         @id @default(autoincrement())
  subCategoria        String      @unique
  nombre              String      @unique
  categoriaId         Int
  relacionCategoria   Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  videos              Video[]     // Relación con videos
  documentos          Documento[] // Relación con documentos
}


// Nuevo modelo de Video  
model Video {
  id              Int           @id @default(autoincrement())
  tema            String
  temaId          Int
  menuCategoria   MenuCategoria @relation(fields: [temaId], references: [id], onDelete: Cascade)
  titulo          String
  tipo            String        @default("URL") // Cambiamos el default a "URL" o algo genérico
  // NUEVOS CAMPOS PARA VIDEOS EXTERNOS en YT Y DAILYMOTION:
  idYoutube       String?       // ID específico de YouTube (Ej: 'dQw4w9WgXcQ')
  idDailymotion   String?       // ID específico de Dailymotion
  plataforma      String?       // Indica la plataforma principal ('YOUTUBE' o 'DAILYMOTION')
  // Se elimina 'url' y 'rutaLocal' ya que no se ajustan al nuevo flujo

  descripcion     String?
  duracion        String?
  categorias      String?
  fechaSubida     DateTime      @default(now())
  miniatura       String?       // Aquí guardaremos la URL de la miniatura
  formato         String?       // Ya no es tan relevante, pero se puede mantener
}

model Documento {
  id              Int           @id @default(autoincrement())
  tema            String
  temaId          Int
  menuCategoria   MenuCategoria @relation(fields: [temaId], references: [id], onDelete: Cascade)
  titulo          String
  tipo            String?       @default("PDF")
  url             String?       
  portada         String?       
  descripcion     String?
  categorias      String?
  fechaSubida     DateTime      @default(now())
  formato         String?       // doc, pdf, ppt, etc.
  contenidoHTML   String?       // Campo para almacenar contenido en HTML desde los docx
}


model plantilla {
  id              Int           @id @default(autoincrement())
  tema            String?
  categoria       String
  titulo          String
  tipo            String?       @default("PDF")
  url             String?       
  portada         String?       
  descripcion     String?
  palabrasClave   String?
  fechaSubida     DateTime      @default(now())
  formato         String?       // doc, pdf, ppt, etc.
}

model CategoriaPlantilla {
 id             Int             @id @default(autoincrement())
  categoria      String          @unique
  nombre         String          @unique
  menuCategorias MenuCategoriaPlantilla[] // Relación inversa necesaria para establecer la relacion fk
}

model MenuCategoriaPlantilla {
  id                  Int                @id @default(autoincrement())
  subCategoria        String             @unique
  nombre              String             @unique
  categoriaId         Int
  relacionCategoria   CategoriaPlantilla @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
}

model User {
  id        Int       @id @default(autoincrement())
  rut       String    @unique // Nuevo campo RUT
  nombre    String
  apellido1 String
  apellido2 String
  email     String    @unique
  password  String
  role      String    @default("user")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Borrado lógico (opcional)
}

model Protocolo {
  id            Int       @id @default(autoincrement())
  codigo        String?
  titulo        String
  descripcion   String
  categoria     String
  version       String
  fechaCreacion DateTime
  fechaRevision DateTime
  vigencia      DateTime?
  creadoPor     String
  storageProvider String @default("Blackblaze_B2") // NUEVO: Proveedor de almacenamiento
  formato       String?   // pdf, epub, mobi, etc.
  url           String?   // ANTES: rutaLocal
  portada     String?   // NUEVO: URL de la portada del protocolo
  fechaSubida   DateTime  @default(now())
}

model ManualEquipo {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String?
  categorias  String?
  fechaSubida DateTime @default(now())
  url         String?
  portada     String?  // URL de la portada del manual
}

model Libro {
  id            Int       @id @default(autoincrement())
  titulo        String
  descripcion   String?
  tema          String?
  version       Int?
  anno          Int?
  categorias    String?
  portada       String?  // URL de la portada del libro
  fechaSubida   DateTime  @default(now())
  storageProvider String @default("Blackblaze_B2") // NUEVO: Proveedor de almacenamiento
  formato       String?   // pdf, epub, mobi, etc.
  url           String?   // ANTES: rutaLocal
  googleFileId  String?   // NUEVO: Para guardar el ID de Google Drive
}

model tema{

  id          Int      @id @default(autoincrement())
tema String
}

model preguntas {
  id                Int      @id @default(autoincrement())
  tema              String
  pregunta          String
  alternativas      String
  respuesta         String
  fechaCreacion     DateTime @default(now())
  fechaModificacion DateTime @updatedAt
}
